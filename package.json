{
  "name": "tz-regions-districts",
  "version": "0.1.1",
  "author": "Yusuph Bakari <yuyahcodes@github.com> (https://github.com/yuyahcodes)",
  "homepage": "https://github.com/yuyahcodes/tz-regions-districts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yuyahcodes/tz-regions-districts.git"
  },
  "description": "Tanzania regions and districts dataset for JavaScript and TypeScript apps.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./regions": {
      "types": "./dist/data/regions.d.ts",
      "import": "./dist/data/regions.js"
    },
    "./flat": {
      "types": "./dist/data/flat.d.ts",
      "import": "./dist/data/flat.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "tanzania",
    "regions",
    "districts",
    "geodata",
    "locations",
    "typescript"
  ],
  "license": "MIT",
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.8.2"
  }
}
